{
  "name": "siger_harness_smoke",
  "output_dir": "logs/eval/harness",
  "device": "auto",
  "generation": {
    "max_new_tokens": 80,
    "temperature": 0.2,
    "top_k": 20,
    "top_p": 0.8
  },
  "suites": [
    {
      "name": "dataset_fixture_audit",
      "kind": "dataset_audit",
      "path": "data/eval/harness/code_fixture.jsonl",
