{
  "name": "lampung_dpo",
  "description": "DPO training on Lampung preference pairs using LoRA",
  
  "model_name": "siger_base",
  "base_checkpoint": "./checkpoints/best_model.pt",
  
  "dataset": {
    "path": "data/corpus/preference_pairs_lampung_train.jsonl",
    "format": "preference_jsonl",
    "prompt_field": "prompt",
    "chosen_field": "chosen",
    "rejected_field": "rejected",
    "max_length": 512
  },
  
  "training": {
    "epochs": 3,
    "max_steps": 500,
    "batch_size": 4,
    "gradient_accumulation_steps": 2,
    "learning_rate": 1e-4,
    "warmup_ratio": 0.1,
    "weight_decay": 0.0,
    "max_grad_norm": 1.0,
    "optimizer": "adamw",
    "scheduler": "linear",
    "mixed_precision": "fp32",
    "eval_steps": 100,
    "save_steps": 100,
    "log_steps": 10
  },
  
  "lora": {
    "rank": 8,
    "alpha": 16,
    "dropout": 0.05,
    "target_modules": [
      "in_proj",
      "out_proj",
      "x_proj",
      "dt_proj"
    ],
    "bias": "none"
  },
  
  "dpo": {
    "enabled": true,
    "beta": 0.1,
    "loss_type": "sigmoid",
    "average_log_prob": true,
    "reference_model_path": null,
    "use_reference_model_in_eval": true,
    "log_preference_accuracy": true,
    "log_margin": true
  },
  
  "hardware": {
    "device": "auto",
    "dtype": "bfloat16",
    "num_workers": 2
  },
  
  "output": {
    "output_dir": "./checkpoints/lora/lampung_dpo",
    "save_best_only": true,
    "overwrite_output_dir": true
  }
}
