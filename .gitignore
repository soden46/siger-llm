# SigerLM gitignore

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Virtual environments
.venv/
venv/
env/

# Environment / secrets
.env
.env.local
.env.*.local

# Build / packaging
build/
dist/
*.egg-info/
.eggs/

# Logs
*.log
logs/

# Large generic pretraining data and caches
data/raw/
data/processed/
data/cache/

# Keep small curated/general seed files and generated instruction corpora.
!data/*.txt
!data/corpus/
!data/corpus/*.jsonl

# Lampung data policy:
# - keep curated raw JSONL
# - keep processed JSONL/TXT/JSON outputs needed to rebuild final data
# - keep final JSONL instruction/corpus outputs needed to train/run
# - do not commit raw PDF sources unless their redistribution license is explicit
data/lampung/raw/*.pdf
!data/lampung/raw/*.jsonl
!data/lampung/processed/
!data/lampung/processed/*.jsonl
!data/lampung/processed/*.json
!data/lampung/processed/*.txt
!data/lampung/final/
!data/lampung/final/*.jsonl

# Feedback data can be useful, but raw unreviewed user feedback may contain
# private content. Commit only approved feedback exports.
data/feedback/
!data/feedback/approved_corrections.jsonl
!data/feedback/README.md

# Checkpoints and model artifacts
checkpoints/base/
checkpoints/lora/
checkpoints/quantized/
models/

*.pt
*.pth
*.bin
*.safetensors
*.onnx

# Keep tokenizer configs/assets if intentionally committed.
!checkpoints/tokenizer/
!checkpoints/tokenizer/tokenizer_config.json
!checkpoints/tokenizer_hf_bpe/
!checkpoints/tokenizer_hf_bpe/vocab.json
!checkpoints/tokenizer_hf_bpe/merges.txt

# Experiment tracking
runs/
wandb/
mlruns/

# Jupyter
.ipynb_checkpoints/

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/
