      "required_fields": ["instruction", "output"],
      "allowed_licenses": ["MIT", "Apache-2.0"],
      "max_row_tokens": 512
    },
    {
      "name": "general_generation_smoke",
      "kind": "generation",
      "path": "data/eval/harness/general_smoke.jsonl",
      "max_cases": 3,
      "required": true
    },
    {
      "name": "lampung_router_regression",
      "kind": "router",
      "path": "data/eval/harness/lampung_router.jsonl",
      "max_cases": 3,
      "required": true
    },
    {
      "name": "lampung_lookup_regression",
      "kind": "lampung_lookup",
      "path": "data/eval/harness/lampung_lookup.jsonl",
      "max_cases": 3,
      "required": true
    }
  ]
}
